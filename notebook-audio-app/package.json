{
  "name": "notebook-audio-app",
  "version": "1.0.0",
  "private": true,
  "description": "Notebook-Style Audio Overview App - React Native + NestJS monorepo",
  "scripts": {
    "dev": "pnpm --filter api dev",
    "start": "pnpm --filter mobile start",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "db:up": "docker compose -f infra/docker-compose.yml up -d",
    "db:down": "docker compose -f infra/docker-compose.yml down",
    "db:migrate": "pnpm --filter api prisma:migrate",
    "db:seed": "pnpm --filter api prisma:seed",
    "db:generate": "pnpm --filter api prisma:generate"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=8"
  },
  "packageManager": "pnpm@8.15.0"
}
