# Database
DATABASE_URL="postgresql://notebook:notebook_password@localhost:5432/notebook_db"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# OpenAI (for embeddings, chat, TTS)
OPENAI_API_KEY=sk-your-openai-api-key

# Optional: ElevenLabs (for premium TTS)
ELEVENLABS_API_KEY=

# Optional: Azure Speech (for TTS)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus

# Optional: Piper (local TTS fallback)
PIPER_MODEL_PATH=/path/to/piper/models

# S3/MinIO Storage
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=notebook
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_REGION=us-east-1
S3_PUBLIC_URL=http://localhost:9000

# TTS Configuration
TTS_DEFAULT_PROVIDER=openai

# Server
PORT=3000
NODE_ENV=development
